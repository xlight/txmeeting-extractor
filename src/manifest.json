{
  "manifest_version": 3,
  "name": "腾讯会议信息提取器",
  "version": "1.3.1",
  "description": "从腾讯会议云录屏页面提取会议信息并导出为 Markdown 格式",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://meeting.tencent.com/*"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meeting.tencent.com/*"],
      "js": ["content/injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://meeting.tencent.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "update_url": "http://upext.chrome.360.cn/intf.php?method=ExtUpdate.query"
}
